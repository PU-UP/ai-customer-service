##
# Stock-ish default server block backup.
# Note: this is a reference copy shipped with the repo. Your system's actual
# /etc/nginx/sites-available/default may differ by distro/package version.
##

server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name _;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    location / {
        try_files $uri $uri/ =404;
    }
}

