DEBUG=0
WORKER_COUNT=1
CHANNEL_DRIVER=wecom_webhook
SCENARIO=tennis_club

# 企业微信配置
TOKEN=your_token
ENCODING_AES_KEY=your_encoding_aes_key
CORP_ID=your_corp_id
CORP_SECRET=your_corp_secret

# LLM API Key（通用命名）
# 兼容 OpenAI / DashScope / 阿里兼容模式等：代码会按以下顺序取值：
# LLM_API_KEY -> OPENAI_API_KEY -> ALI_API_KEY -> DASHSCOPE_API_KEY
LLM_API_KEY=your_llm_api_key
# OPENAI_BASE_URL / LLM_BASE_URL 二选一即可（不填则默认 DashScope 兼容地址）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 场景资产（默认会根据 SCENARIO 自动指向 app/scenarios/<SCENARIO>/）
# 若你要手动覆盖，可以显式指定以下路径：
CLUB_PROFILE_PATH=./app/scenarios/tennis_club/club_profile.json
FAQ_PATH=./app/scenarios/tennis_club/faq.json
SYSTEM_PROMPT_PATH=./app/scenarios/tennis_club/system_prompt.txt

# SQLite 路径：未来运行时数据文件位于 app/data/
SQLITE_PATH=./app/data/ai_customer_service.db

LLM_TIMEOUT_SECONDS=15
CONV_HISTORY_LIMIT=8
CONV_HISTORY_MAX_CHARS=2000
# 0 表示不截断回复；>0 时按字符数截断（用于渠道有硬性长度限制时）
REPLY_TRUNCATE_MAX_CHARS=0
CUSTOMER_PROFILE_REFRESH_SECONDS=86400

