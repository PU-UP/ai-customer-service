# 运行模式
CHANNEL_DRIVER=wecom_webhook
WORKER_COUNT=1
DEBUG=0

# 管理后台（/admin）
# - 用于在网页里编辑本地资产目录中的 club_profile / faq / system_prompt
# - 必填：ADMIN_TOKEN（不设置将无法访问后台）
ADMIN_TOKEN=change_me

# 用户工作目录（推荐仅配置这一项）
# - 程序只从 <USER_WORK_DIR>/assets 读取定制化资产（扁平结构）
# - SQLite 默认位于 <USER_WORK_DIR>/data/ai_customer_service.db
# - assets 目录下直接放 3 个文件：
#   club_profile.json / faq.json / system_prompt.txt
USER_WORK_DIR=./app/user_workdir

# 企业微信配置
TOKEN=your_token
ENCODING_AES_KEY=your_encoding_aes_key
CORP_ID=your_corp_id
CORP_SECRET=your_corp_secret

# LLM API Key（通用命名）
# 兼容 OpenAI / DashScope / 阿里兼容模式等：代码会按以下顺序取值：
# LLM_API_KEY -> OPENAI_API_KEY -> ALI_API_KEY -> DASHSCOPE_API_KEY
LLM_API_KEY=your_llm_api_key
# OPENAI_BASE_URL / LLM_BASE_URL 二选一即可（不填则默认 DashScope 兼容地址）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 运行参数
LLM_TIMEOUT_SECONDS=15
CONV_HISTORY_LIMIT=8
CONV_HISTORY_MAX_CHARS=2000
# 0 表示不截断回复；>0 时按字符数截断（用于渠道有硬性长度限制时）
REPLY_TRUNCATE_MAX_CHARS=0
CUSTOMER_PROFILE_REFRESH_SECONDS=86400

